{
  "name": "muja-portfolio",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint:src": "eslint \"src/**/*.{ts,tsx,jsx}\" --max-warnings 0",
    "lint:vite": "eslint vite.config.ts -c .eslintrc-vite.cjs",
    "lint": "npm run lint:src && npm run lint:vite",
    "lint:src:fix": "eslint \"src/**/*.{ts,tsx,jsx}\" --fix",
    "lint:vite:fix": "eslint vite.config.ts -c .eslintrc-vite.cjs --fix",
    "lint:fix": "npm run lint:src:fix && npm run lint:vite:fix",
    "preview": "vite preview",
    "ts:check": "tsc --noEmit",
    "ts:watch": "tsc --noEmit --watch",
    "format": "prettier --write \"src/**/*.{ts,tsx,jsx,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "optimize:models": "node scripts/optimize-models.mjs",
    "validate": "npm run ts:check && npm run lint && npm run test && npm run build",
    "prepare": "husky install"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.4.2",
    "@fortawesome/free-solid-svg-icons": "^6.4.2",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "framer-motion": "^10.12.16",
    "maath": "^0.5.3",
    "react": "^18.2.0",
    "react-confetti": "^6.1.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^9.0.1",
    "react-tilt": "^1.0.2",
    "react-vertical-timeline-component": "^3.6.0",
    "swiper": "^11.1.14",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.1.1",
    "@gltf-transform/functions": "^4.1.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.38.0",
    "eslint-import-resolver-typescript": "^3.8.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "husky": "^8.0.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.4.23",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "vite.config.ts": [
      "eslint --fix -c .eslintrc-vite.cjs"
    ],
    "*.{css,md}": "prettier --write"
  }
}
